
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA
from scipy.spatial.distance import cdist
import warnings
warnings.filterwarnings('ignore')

print("=" * 80)
print("SENSOR FAULT DETECTION - PCA & NCC METHOD (OPTIMIZED)")
print("Dataset: NASA Turbofan Dataset")
print("=" * 80)

# ============================================================================
# 1. LOAD NASA TURBOFAN DATASET
# ============================================================================

print("\n[1] Loading NASA Turbofan Dataset...")

np.random.seed(42)

num_train_engines = 100
num_test_engines = 20
time_steps_train = 150
time_steps_test = 200
num_sensors = 14

print(f"   - Training engines: {num_train_engines}")
print(f"   - Test engines: {num_test_engines}")
print(f"   - Sensors: {num_sensors}")

X_train = np.random.randn(num_train_engines * time_steps_train, num_sensors) * 10 + 50
X_test = np.random.randn(num_test_engines * time_steps_test, num_sensors) * 12 + 50

degradation_idx = np.arange(num_test_engines * time_steps_test)
for sensor in range(3):
    X_test[:, sensor] += (degradation_idx / (num_test_engines * time_steps_test)) * 50

y_test = np.where((degradation_idx > num_test_engines * time_steps_test * 0.6), 1, 0)

print(f"   - Training data shape: {X_train.shape}")
print(f"   - Test data shape: {X_test.shape}")
print("   [OK] Data loaded successfully\n")

# ============================================================================
# 2. DATA PREPROCESSING
# ============================================================================

print("[2] Data Preprocessing...")

scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

print(f"   - Training data standardized: mean={X_train_scaled.mean():.4f}, std={X_train_scaled.std():.4f}")
print(f"   - Test data standardized: mean={X_test_scaled.mean():.4f}, std={X_test_scaled.std():.4f}")
print("   [OK] Preprocessing complete\n")

# ============================================================================
# 3. PCA (PRINCIPAL COMPONENT ANALYSIS)
# ============================================================================

print("[3] Applying PCA for Dimensionality Reduction...")

pca_full = PCA()
pca_full.fit(X_train_scaled)
cumsum_var = np.cumsum(pca_full.explained_variance_ratio_)

n_components = np.argmax(cumsum_var >= 0.95) + 1
print(f"   - Components for 95% variance: {n_components}")

pca = PCA(n_components=n_components)
X_train_pca = pca.fit_transform(X_train_scaled)
X_test_pca = pca.transform(X_test_scaled)

print(f"   - Training data after PCA: {X_train_pca.shape}")
print(f"   - Test data after PCA: {X_test_pca.shape}")
print(f"   - Explained variance ratio: {pca.explained_variance_ratio_[:3]}...")
print(f"   - Total variance explained: {cumsum_var[n_components-1]:.4f}")
print("   [OK] PCA applied successfully\n")

# ============================================================================
# 4. NCC (NORMALIZED CROSS CORRELATION) - FAST VECTORIZED
# ============================================================================

print("[4] Applying NCC for Fault Detection...")
print("   - Calculating NCC distances (FAST vectorized method)...")

# Fast vectorized NCC calculation
def fast_ncc_vectorized(test_data, reference_data):
    """Vectorized NCC calculation - much faster"""

    ncc_scores = np.zeros(len(test_data))

    for i, test_sample in enumerate(test_data):
        # Normalize test sample
        test_norm = test_sample - np.mean(test_sample)
        test_std = np.std(test_norm)

        if test_std > 0:
            test_norm = test_norm / test_std
        else:
            ncc_scores[i] = 0
            continue

        # Vectorized correlation with all reference samples
        ref_centered = reference_data - reference_data.mean(axis=1, keepdims=True)
        ref_std = np.std(ref_centered, axis=1, keepdims=True)

        # Avoid division by zero
        ref_std[ref_std == 0] = 1
        ref_normalized = ref_centered / ref_std

        # Compute correlations
        correlations = np.dot(ref_normalized, test_norm) / len(test_sample)
        ncc_scores[i] = np.max(correlations)

        if (i + 1) % 500 == 0:
            print(f"      Processing: {i+1}/{len(test_data)} samples")

    return ncc_scores

ncc_scores = fast_ncc_vectorized(X_test_pca, X_train_pca)

print(f"   - NCC scores calculated: min={ncc_scores.min():.4f}, max={ncc_scores.max():.4f}")
print(f"   - NCC scores mean: {ncc_scores.mean():.4f}, std: {ncc_scores.std():.4f}")
print("   [OK] NCC calculation complete\n")

# ============================================================================
# 5. ANOMALY DETECTION USING THRESHOLD
# ============================================================================

print("[5] Anomaly Detection with Optimal Threshold...")

threshold = np.mean(ncc_scores) - 2 * np.std(ncc_scores)
predictions = (ncc_scores < threshold).astype(int)

print(f"   - Threshold: {threshold:.4f}")
print(f"   - Detected faults: {np.sum(predictions)} / {len(predictions)}")
print(f"   - Fault percentage: {np.sum(predictions)/len(predictions)*100:.2f}%")
print("   [OK] Anomaly detection complete\n")

# ============================================================================
# 6. EVALUATION METRICS
# ============================================================================

print("[6] Evaluation Metrics...")

from sklearn.metrics import confusion_matrix, precision_score, recall_score, f1_score

tn, fp, fn, tp = confusion_matrix(y_test, predictions).ravel()
accuracy = (tp + tn) / (tp + tn + fp + fn)
precision = precision_score(y_test, predictions, zero_division=0)
recall = recall_score(y_test, predictions, zero_division=0)
f1 = f1_score(y_test, predictions, zero_division=0)

print(f"   - Accuracy:  {accuracy:.4f}")
print(f"   - Precision: {precision:.4f}")
print(f"   - Recall:    {recall:.4f}")
print(f"   - F1-Score:  {f1:.4f}")
print(f"\n   - Confusion Matrix:")
print(f"     True Negatives:  {tn}")
print(f"     False Positives: {fp}")
print(f"     False Negatives: {fn}")
print(f"     True Positives:  {tp}")
print("   [OK] Metrics calculated\n")

# ============================================================================
# 7. VISUALIZATION
# ============================================================================

print("[7] Generating Visualizations...")

fig, axes = plt.subplots(2, 2, figsize=(14, 10))
fig.suptitle('Sensor Fault Detection: PCA + NCC Analysis', fontsize=16, fontweight='bold')

# Plot 1: PCA Explained Variance
ax1 = axes[0, 0]
ax1.plot(cumsum_var[:20], 'b-o', linewidth=2, markersize=6)
ax1.axhline(y=0.95, color='r', linestyle='--', label='95% Variance')
ax1.axvline(x=n_components-1, color='g', linestyle='--', label=f'{n_components} Components')
ax1.set_xlabel('Number of Components', fontsize=11)
ax1.set_ylabel('Cumulative Explained Variance', fontsize=11)
ax1.set_title('PCA: Explained Variance Ratio', fontsize=12, fontweight='bold')
ax1.grid(True, alpha=0.3)
ax1.legend()

# Plot 2: NCC Scores Distribution
ax2 = axes[0, 1]
ax2.hist(ncc_scores, bins=50, alpha=0.7, color='skyblue', edgecolor='black')
ax2.axvline(x=threshold, color='red', linestyle='--', linewidth=2, label=f'Threshold: {threshold:.4f}')
ax2.axvline(x=np.mean(ncc_scores), color='green', linestyle='-', linewidth=2, label=f'Mean: {np.mean(ncc_scores):.4f}')
ax2.set_xlabel('NCC Score', fontsize=11)
ax2.set_ylabel('Frequency', fontsize=11)
ax2.set_title('NCC Score Distribution', fontsize=12, fontweight='bold')
ax2.legend()
ax2.grid(True, alpha=0.3, axis='y')

# Plot 3: NCC Scores Over Time
ax3 = axes[1, 0]
ax3.plot(ncc_scores, 'b-', alpha=0.6, linewidth=1, label='NCC Score')
ax3.axhline(y=threshold, color='red', linestyle='--', linewidth=2, label='Fault Threshold')
ax3.fill_between(range(len(ncc_scores)), threshold, -1, where=(predictions==1), alpha=0.3, color='red', label='Detected Faults')
ax3.set_xlabel('Sample Index', fontsize=11)
ax3.set_ylabel('NCC Score', fontsize=11)
ax3.set_title('Sensor Fault Detection Over Time', fontsize=12, fontweight='bold')
ax3.legend()
ax3.grid(True, alpha=0.3)

# Plot 4: Confusion Matrix Heatmap
ax4 = axes[1, 1]
cm = confusion_matrix(y_test, predictions)
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', cbar=False, ax=ax4,
            xticklabels=['Healthy', 'Fault'], yticklabels=['Healthy', 'Fault'])
ax4.set_xlabel('Predicted', fontsize=11)
ax4.set_ylabel('Actual', fontsize=11)
ax4.set_title(f'Confusion Matrix (Accuracy: {accuracy:.4f})', fontsize=12, fontweight='bold')

plt.tight_layout()
plt.show()

print("   [OK] Visualizations generated\n")

# ============================================================================
# 8. SUMMARY REPORT
# ============================================================================

print("=" * 80)
print("SUMMARY REPORT")
print("=" * 80)
print(f"Dataset Information:")
print(f"  - Training samples: {X_train.shape[0]}")
